{
  "name": "data-management-system",
  "version": "1.0.0",
  "description": "数据管理系统 - 支持Web浏览器和Electron桌面客户端",
  "private": true,
  "author": "dzh",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "cd frontend && npm run dev",
    "dev:electron": "cd frontend && npm run electron:dev",
    "build": "npm run build:web",
    "build:web": "cd frontend && npm run build",
    "build:electron": "cd frontend && npm run electron:build",
    "install:all": "npm install && cd frontend && npm install && cd ../desktop && npm install",
    "start:backend": "cd backend && npm run start:dev"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
